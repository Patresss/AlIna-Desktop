<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="javafx.scene.layout.StackPane" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" styleClass="context-menu-root">
    <VBox spacing="10.0" styleClass="result-popup-container" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="16.0" right="16.0" bottom="12.0" left="16.0"/>
        </padding>

        <Label fx:id="titleLabel" styleClass="result-popup-title"/>

        <TextArea fx:id="contentArea"
                  editable="false"
                  wrapText="true"
                  prefRowCount="6"
                  VBox.vgrow="ALWAYS"
                  HBox.hgrow="ALWAYS"
                  styleClass="result-popup-text"/>

        <HBox spacing="8.0" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="4.0"/>
            </padding>
            <Button fx:id="copyButton" styleClass="result-popup-button"/>
            <Button fx:id="closeButton" styleClass="result-popup-button"/>
        </HBox>
    </VBox>
</fx:root>
